# Database Configuration
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=bookkeepprodb
DATABASE_URL=mysql+pymysql://root:@localhost:3306/bookkeepprodb

# Security & Authentication
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=https://bookkeepro.net

# Contabo / S3-compatible storage
CONTABO_ENDPOINT=https://eu2.contabostorage.com
CONTABO_REGION=eu2
CONTABO_ACCESS_KEY=your_contabo_access_key
CONTABO_SECRET_KEY=your_contabo_secret_key
CONTABO_BUCKET=bookkeepro-docs
PRESIGNED_URL_EXPIRY=3600

# Email Configuration (SMTP)
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
MAIL_FROM=noreply@bookkeepro.net
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_TLS=True
MAIL_SSL_TLS=False
MAIL_FROM_NAME=BookKeepro

# Application Settings
ADMIN_EMAIL=admin@bookkeepro.net
